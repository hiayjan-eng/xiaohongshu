    "@revival/recommendation-service": "workspace:*",
    "@revival/search-service": "workspace:*",
    "@revival/shared-types": "workspace:*",
    "@revival/storage-service": "workspace:*",
    "@revival/storage-runtime": "workspace:*",
    "@vitejs/plugin-react": "^4.3.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
